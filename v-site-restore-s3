#!/bin/bash
# info: run WordPress Restore Backup Site from S3
# options: DOMAIN BACKUP_URL BACKUP_ID SITE_ID SERVER_ID USERNAME ENVIRONMENT
#
# example: v-site-restore-s3 example.com s3://bucket/path/to/backup.tar.gz 42 17 52 username https://example.com/api/status-backups


#/usr/local/hestia/bin/v-site-restore-s3 akrasprint.com 's3://PBN-NEW-1-Backup/DanielaK/DanielaK.2026-03-10_14-40-54.tar' 11 184 52 DanielaK 1585-49-13-3-52.ngrok-free.app
# This function runs restore script for given domain and backup URL.

#----------------------------------------------------------#
#                Variables & Functions                     #
#----------------------------------------------------------#

domain=$1
backup_url=$2
backup_id=$3
site_id=$4
server_id=$5
username=$6
environment=$7


# Includes
source /etc/hestiacp/hestia.conf
source $HESTIA/func/main.sh
source_conf "$HESTIA/conf/hestia.conf"

#----------------------------------------------------------#
#                    Logging Setup                         #
#----------------------------------------------------------#

LOG_ROOT="/backup_restore"
LOG_DIR="$LOG_ROOT/$domain"
LOG_FILE="$LOG_DIR/v-wp-site-restore.log"

mkdir -p "$LOG_DIR"

echo "[$(date '+%F %T')] === Starting restore for $domain ===" >> "$LOG_FILE"
echo "   BACKUP_URL: $backup_url" >> "$LOG_FILE"
echo "   BACKUP_ID:  $backup_id" >> "$LOG_FILE"
echo "   SITE_ID:    $site_id" >> "$LOG_FILE"
echo "   SERVER_ID:    $server_id" >> "$LOG_FILE"
echo "   USERNAME:   $username" >> "$LOG_FILE"
echo "   ENVIRONMENT:   $environment" >> "$LOG_FILE"
echo "--------------------------------------------------------" >> "$LOG_FILE"

#----------------------------------------------------------#
#                       Action                             #
#----------------------------------------------------------#

# Запускаем скрипт в фоновом режиме, чтобы избежать таймаутов
nohup /usr/local/bin/wp-site-restore-s3.sh "$domain" "$backup_url" "$backup_id" "$site_id" "$server_id" "$username" "$environment" \
    >>"$LOG_FILE" 2>&1 &

RESTORE_PID=$!

echo "[$(date '+%F %T')] Restore started in background with PID: $RESTORE_PID" >> "$LOG_FILE"

#----------------------------------------------------------#
#                       Hestia                             #
#----------------------------------------------------------#

# Логируем старт процесса
log_event "$OK" "$ARGUMENTS"
RESTORE_STATUS="started"
RESTORE_MESSAGE="Restore process for $domain started in background (PID: $RESTORE_PID). Check logs at $LOG_DIR/restore.log"
echo "[$(date '+%F %T')] Process started for $domain (PID: $RESTORE_PID)" >> "$LOG_FILE"

echo "--------------------------------------------------------" >> "$LOG_FILE"

#----------------------------------------------------------#
#                      JSON Response                       #
#----------------------------------------------------------#

JSON=$(cat <<EOF
{
  "domain": "$domain",
  "backup_url": "$backup_url",
  "backup_id": "$backup_id",
  "site_id": "$site_id",
  "server_id": "$server_id",
  "username": "$username",
  "restore_status": "$RESTORE_STATUS",
  "restore_message": "$RESTORE_MESSAGE",
  "pid": $RESTORE_PID,
  "log_file": "$LOG_DIR/restore.log"
}
EOF
)

echo "$JSON"
exit 0
